      <option value="4-3-3">4-3-3 (Classico)</option>
      <option value="4-4-2">4-4-2 (Esterni)</option>
      <option value="3-5-2">3-5-2 (Difesa a 3)</option>
    </select>
  </section>

  <section class="campo-calcio" id="campo-dinamico">
    </section>

  <button id="bottone-simula">⚽ SIMULA LE 38 PARTITE</button>

</div>

  <script src="script.js"></script>
